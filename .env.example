# Server
NODE_ENV=development
PORT=9595

# Scanner
SCAN_INTERVAL_MINUTES=30
CHAT_LIMIT=50
THRESHOLD_HOURS=3

# Dashboard auth (leave empty to disable)
DASHBOARD_USER=
DASHBOARD_PASSWORD=

# Notifications (leave empty to disable)
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=
NTFY_PRIORITY=3

GOTIFY_URL=
GOTIFY_TOKEN=
GOTIFY_PRIORITY=5

# Puppeteer executable path (set in Docker to /usr/bin/chromium)
PUPPETEER_EXECUTABLE_PATH=
